# Example environment variables for this project
# Do NOT commit real secrets. Copy to .env or set in your deployment provider.

### Frontend (Vite)
# Public site key for Google reCAPTCHA v3 (exposed to the browser)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

### Backend (Netlify Functions / Node)
# Secret key to verify reCAPTCHA tokens server-side
RECAPTCHA_SECRET=your_recaptcha_secret_here

# SMTP settings used to send verification emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@example.com

# Application URL used to build verification links (include protocol)
APP_URL=http://localhost:5173

# MongoDB connection string (example placeholder)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/mydb

# JWT secret used by server-side auth (keep this secret)
JWT_SECRET=replace_with_a_strong_random_value
